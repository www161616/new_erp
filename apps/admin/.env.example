# Copy to .env.local and fill in values
# NEXT_PUBLIC_* vars are baked into the static export at build time.

NEXT_PUBLIC_SUPABASE_URL=https://anfyoeviuhmzzrhilwtm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from Supabase dashboard → Project Settings → API → anon/publishable key>

# Optional: basePath for GitHub Pages subpath deploy
# e.g. /new_erp (when deployed to www161616.github.io/new_erp/)
# Leave empty for root deploy / custom domain.
NEXT_PUBLIC_BASE_PATH=
